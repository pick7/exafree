# ExaFree example environment file
# Copy to .env and adjust as needed.

PORT=7860
CONFIG_FILE=data/settings.yaml

# Set to 1 to run API-only mode without the admin panel.
DISABLE_ADMIN_PANEL=0

# Session/admin defaults for local source deployments.
SESSION_SECRET_KEY=change_me_session_secret
ADMIN_KEY=change_me_admin_key

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:7860
ALLOW_ALL_ORIGINS=0

# Optional overrides
# DATABASE_URL=
# ADMIN_PANEL_STATIC_DIR=
